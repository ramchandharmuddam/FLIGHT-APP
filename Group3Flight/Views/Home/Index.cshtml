@model Group3Flight.Models.AirlineViewModel

@{
    ViewData["Title"] = "SkySearch - Find Your Perfect Flight";
}

<div class="home-container">
    <div class="hero-banner">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">Welcome to SkySearch</div>
            <h1 class="hero-title">Discover Your Next<br><span class="gradient-text">Adventure</span></h1>
            <p class="hero-subtitle">Find the best flights at the best prices</p>
        </div>
    </div>

    <div class="content-wrapper">
        <div class="filter-card">
            <div class="filter-header">
                <h3>Find Your Flight</h3>
                <p>Search and filter available flights</p>
            </div>

            <form method="post" asp-action="Index" class="filter-form">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="activeCabinType">
                            Cabin Class
                        </label>
                        <select name="activeCabinType" id="activeCabinType" class="form-control modern-select">
                            <option value="All" selected="@(Model.ActiveCabinType == "All")">All</option>
                            @foreach (var cabin in Model.CabinTypes)
                            {
                                <option value="@cabin" selected="@(Model.ActiveCabinType == cabin)">
                                    @cabin
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="activeFromKey">
                            Departure City
                        </label>
                        <select name="activeFromKey" id="activeFromKey" class="form-control modern-select">
                            <option value="" selected="@(string.IsNullOrEmpty(Model.ActiveFromKey))"></option>
                            @foreach (Group3Flight.Models.Flight C in Model.Flight)
                            {
                                <option value="@C.From" selected="@(Model.ActiveFromKey == C.From.ToString())">
                                    @C.From
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="activeToKey">
                            Arrival City
                        </label>
                        <select name="activeToKey" id="activeToKey" class="form-control modern-select">
                            <option value="" selected="@(string.IsNullOrEmpty(Model.ActiveToKey))"></option>
                            @foreach (Group3Flight.Models.Flight C in Model.Flight)
                            {
                                <option value="@C.To" selected="@(Model.ActiveToKey == C.To.ToString())">
                                    @C.To
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="ActiveDepartureDate">
                            Departure Date
                        </label>
                        <input type="date"
                               id="departureDate"
                               asp-for="ActiveDepartureDate"
                               class="form-control" />
                    </div>
                </div>

                <div class="filter-actions">
                    <button type="submit" class="btn-search">
                        Search Flights
                    </button>
                    <a asp-action="Index" class="btn-reset">Reset Filters</a>
                </div>
            </form>
        </div>

        <div class="results-section">
            <div class="results-header">
                <div class="results-info">
                    <span class="results-count">@(Model.Flight?.Count() ?? 0)</span>
                    <span class="results-label">Flights Found</span>
                </div>
                <div class="results-sort">
                    <span>Sort by: </span>
                    <select class="sort-select">
                        <option>Price: Low to High</option>
                        <option>Price: High to Low</option>
                        <option>Duration: Shortest</option>
                        <option>Departure: Earliest</option>
                    </select>
                </div>
            </div>

            @if (Model.Flight != null && Model.Flight.Any())
            {
                <div class="flights-grid">
                    @foreach (var flight in Model.Flight)
                    {
                        <div class="flight-card">
                            <div class="flight-card-inner">
                                <div class="flight-airline">
                                    <img src="~/images/@(flight.Airline?.ImageName)"
                                         class="airline-logo"
                                         alt="Airline" />
                                    <div class="airline-name">
                                        @(flight.Airline?.ImageName?.Replace(".jpg", "").Replace(".png", "") ?? "Unknown Airline")
                                    </div>
                                </div>

                                <div class="flight-route">
                                    <div class="route-point">
                                        <div class="city-code">@flight.From</div>
                                        <div class="city-time">@flight.DepartureTime</div>
                                    </div>
                                    <div class="route-duration">
                                        <div class="duration-line"></div>
                                        <div class="duration-text">
                                            @{
                                                var duration = flight.ArrivalTime - flight.DepartureTime;
                                                if (duration.TotalMinutes < 0)
                                                {
                                                    duration = duration.Add(TimeSpan.FromHours(24));
                                                }
                                            }
                                            @duration.ToString(@"hh\:mm")
                                        </div>
                                    </div>
                                    <div class="route-point">
                                        <div class="city-code">@flight.To</div>
                                        <div class="city-time">@flight.ArrivalTime</div>
                                    </div>
                                </div>

                                <div class="flight-details">
                                    <div class="detail-chip">
                                        <span>@flight.CabinType</span>
                                    </div>
                                    <div class="detail-chip">
                                        <span>@flight.Emission kg CO₂</span>
                                    </div>
                                    <div class="detail-chip">
                                        <span>@flight.AircraftType</span>
                                    </div>
                                </div>

                                <div class="flight-footer">
                                    <div class="flight-price">
                                        <span class="price-currency">$</span>
                                        <span class="price-amount">@flight.Price</span>
                                    </div>
                                    <a asp-action="Details" asp-route-id="@flight.FlightId" class="btn-view">
                                        View Details
                                        <span class="btn-arrow">→</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3>No Flights Found</h3>
                    <p>We couldn't find any flights matching your criteria.</p>
                    <p class="empty-hint">Try adjusting your filters or selecting different dates.</p>
                    <a asp-action="Index" class="btn-clear-filters">Clear All Filters</a>
                </div>
            }
        </div>
    </div>
</div>