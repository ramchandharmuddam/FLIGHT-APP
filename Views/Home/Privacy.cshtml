@{
    ViewData["Title"] = "Privacy Policy";
}

<div style="
    background: linear-gradient(135deg, #c0392b, #e74c3c);
    color: white;
    text-align: center;
    padding: 60px 20px;">
    <h1 style="font-size: 2.5rem; font-weight: 800;">🔒 Privacy Policy</h1>
    <p style="font-size: 1.1rem; margin-top: 10px; opacity: 0.9;">
        How we collect, use, and protect your information.
    </p>
</div>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <h4 class="fw-bold text-danger">1. Information We Collect</h4>
            <hr />
            <p class="text-muted">
                We collect information you provide when you search for flights,
                make bookings, or contact our support team.
            </p>
            <h4 class="fw-bold text-danger">2. How We Use Your Information</h4>
            <hr />
            <p class="text-muted">
                We use collected information to process bookings and improve
                our services. We do not sell your personal data to third parties.
            </p>
            <h4 class="fw-bold text-danger">3. Contact</h4>
            <hr />
            <p class="text-muted">
                Questions? Contact us at support&#64;group3flight.com
            </p>
        </div>
    </div>
</div>